rules_version = '2';

// BSC KU Firestore Security Rules
// Paste into Firebase Console, Firestore Database, Rules, Publish.

service cloud.firestore {
  match /databases/{database}/documents {

    // Admin email allowlist (same list used in admin.html)
    function isAdmin() {
      return request.auth != null &&
        request.auth.token.email in [
          'ahmed921x@gmail.com',
          'abdullaalshewaya66@gmail.com',
          'kmaldebs@gmail.com',
          'biosciclub@gmail.com'
        ];
    }

    // Public content: readable by everyone, writable by admins only.
    // events, notes, advisors, announcements, news, studentGuide,
    // majorSheets, supportSheets, teamMembers, majorResources,
    // aiKnowledge, schedules
    match /events/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /notes/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /advisors/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /scheduleCommittee/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /announcements/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /news/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /studentGuide/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /majorSheets/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /supportSheets/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /teamMembers/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /majorResources/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /aiKnowledge/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /schedules/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // User-generated content (no login required to create).

    // AI chat log: anyone can add, admin reads/deletes.
    match /aiChats/{id} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }

    // Course suggestions: create for everyone, admin reviews.
    match /suggestions/{id} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }

    // Visitor note uploads, pending admin review.
    match /noteSubmissions/{id} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }

    // Course ratings: create + read for everyone.
    // Site only shows approved ones. Status change/delete is admin-only.
    match /courseRatings/{id} {
      allow create: if true;
      allow read: if true;
      allow update, delete: if isAdmin();
    }

    // GPA calculator save data, keyed by device id.
    match /gpaData/{deviceId} {
      allow read, write: if true;
    }

    // Visit counters, bumped by exactly +1 per visit.
    match /siteStats/{id} {
      allow read: if true;
      allow create: if request.resource.data.count == 1;
      allow update: if request.resource.data.count == resource.data.count + 1;
    }
    match /dailyVisits/{date} {
      allow read: if true;
      allow create: if request.resource.data.count == 1;
      allow update: if request.resource.data.count == resource.data.count + 1;
    }

    // Everything else: denied by default.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
