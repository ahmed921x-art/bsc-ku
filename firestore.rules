rules_version = '2';

// ====================================================================
//  BSC KU - Firestore Security Rules
//  Paste this file's content into:
//  Firebase Console -> Firestore Database -> Rules -> Publish
//
//  Important: try the rules in "Rules Playground" before publishing,
//  since a mistake here can break the live site's read/write access.
// ====================================================================

service cloud.firestore {
  match /databases/{database}/documents {

    // Admin email allowlist (same list used in admin.html)
    function isAdmin() {
      return request.auth != null &&
        request.auth.token.email in [
          'ahmed921x@gmail.com',
          'abdullaalshewaya66@gmail.com',
          'kmaldebs@gmail.com',
          'biosciclub@gmail.com'
        ];
    }

    // Public content: readable by everyone, writable by admins only.
    // events, notes, advisors, announcements, news, studentGuide,
    // majorSheets, supportSheets, teamMembers, majorResources,
    // aiKnowledge, schedules
    match /events/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /notes/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /advisors/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /scheduleCommittee/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /announcements/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /news/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /studentGuide/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /majorSheets/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /supportSheets/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /teamMembers/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /majorResources/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /aiKnowledge/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /schedules/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // User-generated content (no login required to create).

    // AI assistant chat log: any visitor can add one, admin reads/deletes.
    match /aiChats/{id} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }

    // Course-catalog edit suggestions: create for everyone, admin reviews.
    match /suggestions/{id} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }

    // Notes submitted by visitors, pending admin review before publishing to notes/.
    match /noteSubmissions/{id} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }

    // Course ratings: create + read for everyone (the site only renders
    // status=="approved" ones client-side), status changes + delete admin-only.
    match /courseRatings/{id} {
      allow create: if true;
      allow read: if true;
      allow update, delete: if isAdmin();
    }

    // GPA calculator save data (per-device via deviceId) - no sensitive data.
    match /gpaData/{deviceId} {
      allow read, write: if true;
    }

    // Visit counters: any visitor can bump the count by exactly +1.
    // siteStats/total = all-time total, dailyVisits/{YYYY-MM-DD} = today's count.
    match /siteStats/{id} {
      allow read: if true;
      allow create: if request.resource.data.count == 1;
      allow update: if request.resource.data.count == resource.data.count + 1;
    }
    match /dailyVisits/{date} {
      allow read: if true;
      allow create: if request.resource.data.count == 1;
      allow update: if request.resource.data.count == resource.data.count + 1;
    }

    // Everything else: denied by default.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
